def get_reddit_sentiment(ticker_symbol):
    # 這裡填入你的 Reddit API 憑證
    reddit = praw.Reddit(
        client_id="YOUR_CLIENT_ID",
        client_secret="YOUR_SECRET",
        user_agent="LCCapital_Bot_v1"
    )
    
    subreddit = reddit.subreddit("wallstreetbets")
    # 搜尋包含該股票代碼的最新熱門貼文
    posts = subreddit.search(f"${ticker_symbol}", sort="new", limit=5)
    
    report = "【Reddit WSB 最新相關貼文】\n"
    for post in posts:
        report += f"- 標題: {post.title} (推文數: {post.score}, 留言數: {post.num_comments})\n"
    return report

