# ==========================================
# 1. 抓取期權異常數據 (以 LUMN 為例)
# ==========================================
def get_options_data(ticker_symbol):
    ticker = yf.Ticker(ticker_symbol)
    # 獲取最近到期日的期權鏈
    expirations = ticker.options
    if not expirations:
        return "無期權數據"
    
    chain = ticker.option_chain(expirations[0])
    calls = chain.calls
    puts = chain.puts
    
    # 簡單篩選出成交量異常的合約 (這裡假設大於 1000 口為異常)
    unusual_calls = calls[calls['volume'] > 1000][['strike', 'volume', 'openInterest']]
    unusual_puts = puts[puts['volume'] > 1000][['strike', 'volume', 'openInterest']]
    
    report = f"【期權異動數據 - 最近到期日: {expirations[0]}】\n"
    report += f"異常 Call (成交量>1000): \n{unusual_calls.to_string()}\n"
    report += f"異常 Put (成交量>1000): \n{unusual_puts.to_string()}\n"
    return report

